{
  "redirects": [
    {
      "source": "/portfolio-dashboard",
      "destination": "/portfolio-dashboard/",
      "permanent": false
    },
    {
      "source": "/credit-conc-risk",
      "destination": "/credit-conc-risk/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/custom-portfolio/:path*",
      "destination": "https://custom-portfolio-omega.vercel.app/:path*"
    },
    {
      "source": "/custom-portfolio",
      "destination": "https://custom-portfolio-omega.vercel.app/"
    },
    {
      "source": "/portfolio-dashboard/:path*",
      "destination": "https://portfolio-dashboard-two-pearl.vercel.app/:path*"
    },
    {
      "source": "/portfolio-dashboard/",
      "destination": "https://portfolio-dashboard-two-pearl.vercel.app/"
    },
    {
      "source": "/credit-conc-risk/:path*",
      "destination": "https://credit-conc-risk.vercel.app/:path*"
    },
    {
      "source": "/credit-conc-risk/",
      "destination": "https://credit-conc-risk.vercel.app/"
    },
    {
      "source": "/fund-dashboard/:path*",
      "destination": "https://fund-dashboard-coral.vercel.app/:path*"
    },
    {
      "source": "/fund-dashboard",
      "destination": "https://fund-dashboard-coral.vercel.app/"
    }
  ]
}
